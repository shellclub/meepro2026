generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ==========================================
// หมวดหมู่สินค้า
// ==========================================
model Category {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  slug        String    @unique @db.VarChar(120)
  description String?   @db.Text
  image       String?   @db.VarChar(500)
  parentId    Int?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]

  @@map("categories")
}

// ==========================================
// แบรนด์สินค้า
// ==========================================
model Brand {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  slug        String    @unique @db.VarChar(120)
  logo        String?   @db.VarChar(500)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]

  @@map("brands")
}

// ==========================================
// สินค้า
// ==========================================
model Product {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar(255)
  slug          String    @unique @db.VarChar(280)
  description   String?   @db.Text
  shortDesc     String?   @db.VarChar(500)
  sku           String?   @db.VarChar(50)
  price         Decimal   @db.Decimal(10, 2)
  comparePrice  Decimal?  @db.Decimal(10, 2)
  costPrice     Decimal?  @db.Decimal(10, 2)
  stock         Int       @default(0)
  weight        String?   @db.VarChar(50)
  unit          String?   @db.VarChar(30)
  isFeatured    Boolean   @default(false)
  isActive      Boolean   @default(true)
  status        String    @default("available") @db.VarChar(30) // available, out_of_stock, discontinued
  rating        Decimal   @default(0) @db.Decimal(2, 1)
  reviewCount   Int       @default(0)
  salesCount    Int       @default(0)
  categoryId    Int?
  brandId       Int?
  tags          String?   @db.VarChar(500)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  category      Category?      @relation(fields: [categoryId], references: [id])
  brand         Brand?         @relation(fields: [brandId], references: [id])
  images        ProductImage[]
  variants      ProductVariant[]
  orderItems    OrderItem[]

  @@index([categoryId])
  @@index([brandId])
  @@index([status])
  @@index([isFeatured])
  @@map("products")
}

// ==========================================
// รูปภาพสินค้า (หลายรูปต่อสินค้า)
// ==========================================
model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  url       String  @db.VarChar(500)
  alt       String? @db.VarChar(255)
  sortOrder Int     @default(0)
  isMain    Boolean @default(false)

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

// ==========================================
// ตัวเลือกสินค้า (ขนาด, น้ำหนัก, สี, รสชาติ)
// ==========================================
model ProductVariant {
  id            Int      @id @default(autoincrement())
  productId     Int
  name          String   @db.VarChar(100) // เช่น "ขนาด", "น้ำหนัก", "รสชาติ"
  value         String   @db.VarChar(100) // เช่น "1 kg", "3 kg", "รสไก่"
  priceAdjust   Decimal  @default(0) @db.Decimal(10, 2)
  stock         Int      @default(0)
  sku           String?  @db.VarChar(50)
  isActive      Boolean  @default(true)

  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

// ==========================================
// ลูกค้า
// ==========================================
model Customer {
  id        Int       @id @default(autoincrement())
  firstName String    @db.VarChar(100)
  lastName  String    @db.VarChar(100)
  email     String?   @unique @db.VarChar(255)
  phone     String?   @db.VarChar(20)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  addresses Address[]
  orders    Order[]

  @@map("customers")
}

// ==========================================
// ที่อยู่จัดส่ง
// ==========================================
model Address {
  id          Int      @id @default(autoincrement())
  customerId  Int
  label       String?  @db.VarChar(50) // เช่น "บ้าน", "ที่ทำงาน"
  address     String   @db.Text
  subDistrict String?  @db.VarChar(100)
  district    String?  @db.VarChar(100)
  province    String?  @db.VarChar(100)
  postalCode  String?  @db.VarChar(10)
  phone       String?  @db.VarChar(20)
  isDefault   Boolean  @default(false)

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@index([customerId])
  @@map("addresses")
}

// ==========================================
// คำสั่งซื้อ
// ==========================================
model Order {
  id              Int       @id @default(autoincrement())
  orderNumber     String    @unique @db.VarChar(20)
  customerId      Int
  addressId       Int?
  status          String    @default("pending") @db.VarChar(30) // pending, confirmed, shipping, delivered, cancelled
  paymentMethod   String?   @db.VarChar(50) // transfer, cod
  paymentStatus   String    @default("pending") @db.VarChar(30) // pending, paid, refunded
  subtotal        Decimal   @db.Decimal(10, 2)
  shippingFee     Decimal   @default(0) @db.Decimal(10, 2)
  discount        Decimal   @default(0) @db.Decimal(10, 2)
  total           Decimal   @db.Decimal(10, 2)
  note            String?   @db.Text
  shippingName    String?   @db.VarChar(200)
  shippingAddress String?   @db.Text
  shippingPhone   String?   @db.VarChar(20)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  customer        Customer  @relation(fields: [customerId], references: [id])
  address         Address?  @relation(fields: [addressId], references: [id])
  items           OrderItem[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

// ==========================================
// รายการสินค้าในคำสั่งซื้อ
// ==========================================
model OrderItem {
  id          Int       @id @default(autoincrement())
  orderId     Int
  productId   Int
  variantId   Int?
  productName String    @db.VarChar(255)
  variantName String?   @db.VarChar(200)
  price       Decimal   @db.Decimal(10, 2)
  quantity    Int
  total       Decimal   @db.Decimal(10, 2)

  order       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product        @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ==========================================
// ค่า Config ร้านค้า
// ==========================================
model SiteConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique @db.VarChar(100)
  value String @db.Text
  group String @default("general") @db.VarChar(50)

  @@map("site_configs")
}

// ==========================================
// แบนเนอร์โฆษณา
// ==========================================
model Banner {
  id        Int      @id @default(autoincrement())
  title     String?  @db.VarChar(255)
  subtitle  String?  @db.VarChar(500)
  image     String   @db.VarChar(500)
  link      String?  @db.VarChar(500)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banners")
}

// ==========================================
// ผู้ดูแลระบบ (Admin)
// ==========================================
model AdminUser {
  id        Int       @id @default(autoincrement())
  username  String    @unique @db.VarChar(100)
  password  String    @db.VarChar(255) // Hashed password
  name      String    @db.VarChar(100)
  role      String    @default("admin") @db.VarChar(50) // admin, superadmin
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("admin_users")
}
